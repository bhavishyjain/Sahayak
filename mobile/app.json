{
  "expo": {
    "name": "Sahayak",
    "slug": "sahyak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-ios.png",
    "scheme": "sahayak",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "44",
      "supportsTablet": false,
      "bundleIdentifier": "com.sahayak.mobile",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "whatsapp"
        ],
        "UIBackgroundModes": [
          "remote-notification",
          "location",
          "fetch"
        ],
        "NSCameraUsageDescription": "We need camera access to take photos of civic issues and complaints for reporting to your local municipal authorities.",
        "NSLocationWhenInUseUsageDescription": "We use your location to automatically detect the location of complaints you report and to show nearby civic issues on the heatmap.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to help you report civic complaints at their exact location and to show you relevant issues in your area.",
        "NSLocationAlwaysUsageDescription": "Location access helps us accurately pinpoint civic complaints and show you relevant issues in your community.",
        "NSPhotoLibraryUsageDescription": "We need photo library access so you can attach photos of civic issues and complaints when reporting problems to municipal authorities.",
        "NSMicrophoneUsageDescription": "Microphone access is used for voice assistant input so we can transcribe and help with complaint drafting."
      },
      "associatedDomains": [
        "applinks:sahayak-zqp7.onrender.com"
      ],
      "appleTeamId": "ZLV8X465V5"
    },
    "android": {
      "versionCode": 44,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/logo-android.png",
        "monochromeImage": "./assets/images/splash.png"
      },
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "sahayak"
            },
            {
              "scheme": "https",
              "host": "sahayak-zqp7.onrender.com"
            }
          ]
        }
      ],
      "queries": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "https"
            }
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./android/app/google-services.json",
      "package": "com.sahayak.mobile",
      "statusBar": {
        "translucent": false,
        "backgroundColor": "#191918",
        "barStyle": "light-content"
      },
      "navigationBar": {
        "backgroundColor": "#191918",
        "barStyle": "light-content"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/splash.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "imageWidth": 300,
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Sahayak to access your microphone for voice assistant input."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ic_stat.png",
          "color": "#FFCC00"
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e326588d-9170-4fa5-bba8-fade1fea96e1"
      }
    },
    "owner": "bhavishy-jain"
  }
}
