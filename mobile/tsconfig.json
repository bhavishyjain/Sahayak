{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "app/index.jsx",
    "app/_layout.jsx",
    "app/auth/otp.jsx",
    "app/auth/login.jsx",
    "utils/inAppUpdate.native.ts"
, "app/(app)/order/chat/useChat.js", "app/(app)/order/chat/chatAdapter.js", "app/(app)/order/chat/chatScreen.jsx", "utils/cache/auth.js", "utils/api.js"  ]
}
