{
  "name": "sahayak-mobile",
  "main": "expo-router/entry",
  "version": "5.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "debug:android": "npx expo export --platform android && cd android && ./gradlew clean && ./gradlew assembleDebug && open app/build/outputs/apk/debug",
    "staging:android": "npx expo export --platform android && cd android && ./gradlew clean && ./gradlew assembleStaging && open app/build/outputs/apk/staging",
    "release:android": "cd android && ./gradlew assembleRelease && open app/build/outputs/apk/release",
    "bundle:android": "cd android && ./gradlew bundleRelease && open app/build/outputs/bundle/release",
    "clean:android": "cd android && ./gradlew clean"
  },
  "dependencies": {
    "@microsoft/react-native-clarity": "^4.5.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "~54.0.31",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-localization": "~17.0.8",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.21",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-system-ui": "^55.0.9",
    "i18n-js": "^4.5.1",
    "lottie-react-native": "~7.3.1",
    "lucide-react-native": "^0.562.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-auto-skeleton": "^0.1.30",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "^15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.0",
    "rn-swipe-button": "^3.0.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.0",
    "@react-native/metro-config": "^0.83.1",
    "@types/react": "~19.1.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
